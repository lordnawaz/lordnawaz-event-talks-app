# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if the platform is different, locking is sometimes not
#   desirable.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains the resolved dependencies.
#   According to poetry's documentation, it is recommended to include poetry.lock in version control.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains the resolved dependencies.
#pdm.lock

